<?php

/**
 * @file
 * Quant OPcache module — resets PHP OPcache on Drupal cache rebuilds.
 *
 * OPcache is configured in the quant/app-apache-php base image with
 * revalidate_freq=3600 to minimise EFS metadata I/O. This module's
 * hook_cache_flush() implementation ensures admin-driven changes
 * (module install/uninstall, config import, `drush cr`, etc.) invalidate
 * the bytecode cache immediately on the current container.
 *
 * Other containers in the same service re-sync within revalidate_freq.
 * For emergency propagation, force a new ECS deployment.
 */

/**
 * Implements hook_cache_flush().
 *
 * Triggered by drupal_flush_all_caches() — fires on module install/uninstall,
 * configuration import, `drush cr`, admin "Clear all caches", and similar.
 */
function quant_opcache_cache_flush() {
  if (function_exists('opcache_reset')) {
    @opcache_reset();
    \Drupal::logger('quant_opcache')->info('OPcache reset on cache flush.');
  }
  if (function_exists('clearstatcache')) {
    clearstatcache(TRUE);
  }
}
